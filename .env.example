# database connection pieces — change POSTGRES_DB here ONLY, and both
# the app's connection string and the db container's created database
# name pick it up automatically
POSTGRES_USER=.....
POSTGRES_PASSWORD=...
POSTGRES_HOST=db #put here service name of the db container in docker-compose.yml
POSTGRES_PORT=...
POSTGRES_DB=.....

APP_ENV=...
LOG_LEVEL=...